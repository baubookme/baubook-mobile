{
  "name": "baubook",
  "version": "0.6.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start --clear",
    "dev": "expo start --clear",
    "web": "expo start --web --clear",
    "web:host": "expo start --web --host lan --clear",
    "android": "expo run:android",
    "android:build": "expo run:android",
    "android:start": "expo start --dev-client --android --host lan --clear",
    "android:start:localhost": "expo start --dev-client --android --localhost --clear",
    "android:expo-go": "expo start --android --host lan --clear",
    "typecheck": "tsc --noEmit",
    "doctor": "powershell -ExecutionPolicy Bypass -File ./scripts/doctor.ps1",
    "expo:check": "npx expo install --check",
    "export:web": "expo export --platform web --dev --no-minify --max-workers 1 --clear",
    "export:android": "expo export --platform android --no-minify --max-workers 1 --clear",
    "export:web:prod": "expo export --platform web --max-workers 1 --clear",
    "install:clean": "powershell -ExecutionPolicy Bypass -File ./scripts/install-clean.ps1",
    "bb:web": "powershell -ExecutionPolicy Bypass -File ./baubook.ps1 -Mode web",
    "bb:android-build": "powershell -ExecutionPolicy Bypass -File ./baubook.ps1 -Mode android-build",
    "bb:android-dev": "powershell -ExecutionPolicy Bypass -File ./baubook.ps1 -Mode android-dev",
    "bb:doctor": "powershell -ExecutionPolicy Bypass -File ./baubook.ps1 -Mode doctor",
    "supabase:doctor": "powershell -ExecutionPolicy Bypass -File ./scripts/supabase-doctor.ps1",
    "bb:supabase": "powershell -ExecutionPolicy Bypass -File ./baubook.ps1 -Mode supabase-doctor",
    "safety:smoke": "powershell -ExecutionPolicy Bypass -File ./scripts/safety-smoke-check.ps1",
    "launch:check": "node scripts/check-launch-readiness-207.js",
    "launch:check:strict": "node scripts/check-launch-readiness-207.js --strict",
    "docs:check": "powershell -ExecutionPolicy Bypass -File ./scripts/docs-structure-check.ps1",
    "beta:check": "npm run docs:check && npm run launch:check && npm run typecheck",
    "ui:check": "powershell -ExecutionPolicy Bypass -File ./scripts/ui-smoke-check.ps1",
    "baubook:release:doctor": "node scripts/baubook-release-doctor.mjs --expected-version 0.3.1 --expected-baseline 2.0.1 --expected-android-version-code 14 --expected-ios-build-number 14",
    "map:realtime:check": "powershell -ExecutionPolicy Bypass -File ./scripts/map-realtime-check.ps1",
    "map:native:check": "powershell -ExecutionPolicy Bypass -File ./scripts/map-native-check.ps1",
    "map:web-safe:check": "node scripts/check-web-safe-maps.js",
    "sponsored:rls:check": "node scripts/check-sponsored-slots-rls-sql.js",
    "device:beta:check": "node scripts/check-launch-readiness-207.js --device-beta",
    "no-store:check": "node scripts/check-launch-readiness-207.js --no-store",
    "store:fasttrack:check": "node scripts/check-no-store-device-launch.js --store",
    "sponsor:pilot:check": "node scripts/check-no-store-device-launch.js --sponsor",
    "home:badges:check": "node scripts/check_home_badges.js",
    "beta:polish:check": "node scripts/check_beta_polish.js",
    "first-steps:check": "node scripts/check_first_steps.js",
    "contact:embedded:check": "node scripts/check_embedded_contact.js",
    "dog:diary:check": "node scripts/check_dog_diary.js",
    "dog:diary:smart:check": "node scripts/check_dog_diary_smart_summary.js",
    "map:care:check": "node scripts/check_map_care_command_center.js",
    "production:backend:check": "node scripts/check_production_backend_cutover.js",
    "production:no-demo-check": "node scripts/check_no_demo_runtime.js",
    "presentability:check": "node scripts/check_presentability.js",
    "production:cutover:check": "npm run production:backend:check && npm run production:no-demo-check && npm run presentability:check"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.14",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.107.0",
    "expo": "~56.0.9",
    "expo-dev-client": "^56.0.19",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-maps": "1.27.2",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "baubook": {
    "baseline": "2.3.0",
    "releaseName": "Production Backend Cutover",
    "releaseTag": "v0.6.0-production-backend-cutover",
    "releaseDate": "2026-06-11",
    "label": "Production Backend Cutover"
  }
}
