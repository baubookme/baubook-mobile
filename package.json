{
  "name": "baubook",
  "version": "0.7.4",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start --clear",
    "dev": "expo start --clear",
    "web": "expo start --web --clear",
    "web:host": "expo start --web --host lan --clear",
    "android": "expo run:android",
    "android:start": "expo start --dev-client --android --host lan --clear",
    "android:start:localhost": "expo start --dev-client --android --localhost --clear",
    "android:expo-go": "expo start --android --host lan --clear",
    "android:build": "expo run:android",
    "typecheck": "tsc --noEmit",
    "doctor": "powershell -ExecutionPolicy Bypass -File ./scripts/doctor.ps1",
    "expo:check": "npx expo install --check",
    "install:clean": "powershell -ExecutionPolicy Bypass -File ./scripts/install-clean.ps1",
    "bb:web": "powershell -ExecutionPolicy Bypass -File ./baubook.ps1 -Mode web",
    "bb:android-build": "powershell -ExecutionPolicy Bypass -File ./baubook.ps1 -Mode android-build",
    "bb:android-dev": "powershell -ExecutionPolicy Bypass -File ./baubook.ps1 -Mode android-dev",
    "bb:doctor": "powershell -ExecutionPolicy Bypass -File ./baubook.ps1 -Mode doctor",
    "bb:supabase": "powershell -ExecutionPolicy Bypass -File ./baubook.ps1 -Mode supabase-doctor",
    "supabase:doctor": "powershell -ExecutionPolicy Bypass -File ./scripts/supabase-doctor.ps1",
    "safety:smoke": "powershell -ExecutionPolicy Bypass -File ./scripts/safety-smoke-check.ps1",
    "check": "npm run typecheck && node scripts/baubook-checks.mjs",
    "production:check": "npm run typecheck && node scripts/baubook-checks.mjs --production",
    "launch:check": "node scripts/baubook-checks.mjs --launch",
    "launch:check:strict": "node scripts/baubook-checks.mjs --launch --strict"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.14",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@supabase/supabase-js": "^2.107.0",
    "expo": "~56.0.12",
    "expo-dev-client": "~56.0.20",
    "expo-image-picker": "~56.0.18",
    "expo-location": "~56.0.18",
    "pg": "^8.22.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-maps": "1.27.2",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "baubook": {
    "baseline": "2.3.0",
    "releaseName": "BauBook 0.7.4 Store Metadata & Legal Readiness",
    "releaseTag": "baubook-0.7.4-store-metadata-legal-readiness",
    "releaseDate": "2026-06-25",
    "label": "Store Safety Moderation Readiness",
    "storeLegalReadiness": true,
    "legalUrls": {
      "home": "https://baubook.me/",
      "privacy": "https://baubook.me/privacy/",
      "terms": "https://baubook.me/terms/",
      "communityGuidelines": "https://baubook.me/community-guidelines/",
      "support": "https://baubook.me/support/",
      "accountDeletion": "https://baubook.me/account-deletion/"
    }
  }
}
