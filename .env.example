# BauBook! public Expo environment
# Copy this file to .env and fill local values. Do not commit .env.

EXPO_PUBLIC_APP_ENV=local

# Supabase managed backend
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Maps. Keep empty until the Android key is ready.
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_API_KEY=

# Sponsored Places Lite. Default must stay false for beta/store safety.
EXPO_PUBLIC_BAUBOOK_SPONSORED_LITE_ENABLED=false

# Public legal/support links shown in app and checked by launch scripts.
EXPO_PUBLIC_BAUBOOK_CONTACT_EMAIL=support@baubook.me
EXPO_PUBLIC_BAUBOOK_PRIVACY_URL=https://baubook.me/privacy
EXPO_PUBLIC_BAUBOOK_TERMS_URL=https://baubook.me/terms
EXPO_PUBLIC_BAUBOOK_DELETE_ACCOUNT_URL=https://baubook.me/account-deletion/
