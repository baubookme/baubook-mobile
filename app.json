{
  "expo": {
    "name": "BauBook! Venezia-Mestre",
    "slug": "baubook",
    "version": "0.2.9",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "baubook",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8ED"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "me.baubook.app",
      "buildNumber": "12",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "me.baubook.app",
      "adaptiveIcon": {
        "backgroundColor": "#FFF8ED",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "versionCode": 12
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "name": "BauBook! Venezia-Mestre",
      "shortName": "BauBook!"
    },
    "extra": {
      "projectName": "BauBook MVP In-App Launch Compliance Workspace 1.9.9",
      "betaCity": "Venezia-Mestre",
      "preferredDevFlow": "web + Android development build + Supabase Auth + walks + safety alerts + compact docs",
      "baseline": "1.9.9",
      "launchReadiness": "in-app-launch-compliance-docs-compaction",
      "sponsoredLiteDefault": false
    }
  }
}
